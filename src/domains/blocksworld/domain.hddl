(define (domain blocksworld)
  (:requirements :typing :equality :hierarchy :negative-preconditions)
  (:types block)

  (:predicates
    (holding ?b - block)
    (handempty)
    (ontable ?b - block)
    (on ?b1 ?b2 - block)
    (clear ?b - block)
  )

  (:task place_on
    :parameters (?b1 ?b2 - block)
  )

  (:task hold_block
    :parameters (?b - block)
  )

  (:task clear_top
    :parameters (?b - block)
  )

  (:method m_place_on_stack
    :parameters (?b1 ?b2 - block)
    :task (place_on ?b1 ?b2)
    :precondition (and (not (= ?b1 ?b2)))
    :ordered-subtasks (and
      (s1 (hold_block ?b1))
      (s2 (clear_top ?b2))
      (s3 (put-on-block ?b1 ?b2))
    )
  )

  (:method m_place_on_noop
    :parameters (?b1 ?b2 - block)
    :task (place_on ?b1 ?b2)
    :precondition (and (on ?b1 ?b2))
    :ordered-subtasks (and)
  )

  (:method m_hold_block_from_table
    :parameters (?b - block)
    :task (hold_block ?b)
    :precondition (and (handempty) (clear ?b) (ontable ?b))
    :ordered-subtasks (and
      (s1 (pick-up-from-table ?b))
    )
  )

  (:method m_hold_block_from_stack
    :parameters (?b ?support - block)
    :task (hold_block ?b)
    :precondition (and
      (not (= ?b ?support))
      (handempty)
      (clear ?b)
      (on ?b ?support)
    )
    :ordered-subtasks (and
      (s1 (pick-up ?b ?support))
    )
  )

  (:method m_hold_block_noop
    :parameters (?b - block)
    :task (hold_block ?b)
    :precondition (and (holding ?b))
    :ordered-subtasks (and)
  )

  (:method m_clear_top_noop
    :parameters (?b - block)
    :task (clear_top ?b)
    :precondition (and (clear ?b))
    :ordered-subtasks (and)
  )

  (:action pick-up
    :parameters (?b1 ?b2 - block)
    :precondition (and (not (= ?b1 ?b2)) (handempty) (clear ?b1) (on ?b1 ?b2))
    :effect (and
      (holding ?b1)
      (clear ?b2)
      (not (handempty))
      (not (clear ?b1))
      (not (on ?b1 ?b2))
    )
  )

  (:action pick-up-from-table
    :parameters (?b - block)
    :precondition (and (handempty) (clear ?b) (ontable ?b))
    :effect (and (holding ?b) (not (handempty)) (not (ontable ?b)))
  )

  (:action put-on-block
    :parameters (?b1 ?b2 - block)
    :precondition (and (not (= ?b1 ?b2)) (holding ?b1) (clear ?b2))
    :effect (and
      (on ?b1 ?b2)
      (handempty)
      (clear ?b1)
      (not (holding ?b1))
      (not (clear ?b2))
    )
  )

  (:action put-down
    :parameters (?b - block)
    :precondition (holding ?b)
    :effect (and (ontable ?b) (handempty) (clear ?b) (not (holding ?b)))
  )
)
