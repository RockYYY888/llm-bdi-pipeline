# OpenAI API Configuration
OPENAI_API_KEY=
METHOD_SYNTHESIS_OPENAI_API_KEY=

# Optional: Shared model selection
OPENAI_MODEL=moonshotai/kimi-k2.6
GOAL_GROUNDING_MODEL=moonshotai/kimi-k2.6

# Optional: Base URL
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: API timeout (seconds)
OPENAI_TIMEOUT=1000

# Optional: evaluation runtime domain source
# benchmark = use the benchmark domain as the evaluation base domain
# generated = materialize a generated evaluation domain from the stored M artifact
EVALUATION_DOMAIN_SOURCE=benchmark
