# OpenAI API Configuration
OPENAI_API_KEY=

# Optional: Shared model selection
OPENAI_MODEL=minimax/minimax-m2.7
GOAL_GROUNDING_MODEL=minimax/minimax-m2.7

# Optional: Base URL
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: API timeout (seconds)
OPENAI_TIMEOUT=160

# Optional: online runtime domain source
# benchmark = use the benchmark domain as the online base domain
# generated = use the cached generated_domain.hddl from the offline artifact
ONLINE_DOMAIN_SOURCE=benchmark
